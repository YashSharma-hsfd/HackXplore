# Local virtualenv (rebuilt inside container)
.venv/
venv/

# Python bytecode + tool caches
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Logs. NOTE: chroma_store/ + graph_store/ are intentionally NOT ignored — they
# are baked into the image (see Dockerfile) so the HF Spaces deploy answers
# immediately; there's no host volume to mount there.
*.log

# Secrets — passed via env_file at runtime, never baked into the image
.env
.env.*

# Tests + dev files
tests/
eval/
scripts/
.github/
.vscode/
.idea/

# VCS
.git/
.gitignore

# OS junk
Thumbs.db
.DS_Store

# Docker artifacts
Dockerfile
docker-compose.yml
.dockerignore

# Build artifacts
build/
dist/
