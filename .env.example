# ============================================================================
#  rag-service (Two-Stroke Knowledge DB) — environment template
#  Copy to .env and fill in. The ONLY key you really need to answer queries is
#  OPENROUTER_API_KEY (it powers both generation and the eval judge).
# ============================================================================

# --- Generation LLM (chatbot answers + ingest tagging/triples) --------------
# Mistral Small 3.2 24B via OpenRouter (OpenAI-compatible). This is the key
# teammates need. LLM_MODEL / LLM_BASE_URL have working defaults in config.py;
# only set them to switch provider (e.g. a local vLLM/Ollama endpoint).
OPENROUTER_API_KEY=your_openrouter_api_key_here
# LLM_MODEL=mistralai/mistral-small-3.2-24b-instruct
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=                      # if set, overrides OPENROUTER_API_KEY for generation

# --- Embeddings + reranker (LOCAL, no key) ----------------------------------
# BGE-M3 + bge-reranker-v2-m3 run locally via sentence-transformers. Defaults
# live in config.py; no env needed. Don't change EMBEDDING_MODEL after ingest
# (it invalidates every stored vector — full re-index).
# EMBEDDING_MODEL=BAAI/bge-m3

# --- Web search (OPTIONAL — the "web search" toggle on /query) ---------------
# Tavily (https://tavily.com, free tier = 1000 searches/mo). Without this key,
# web_search=true returns HTTP 503; normal corpus queries are unaffected.
TAVILY_API_KEY=your_tavily_api_key_here

# --- OCR fallback for scanned PDFs (OPTIONAL) -------------------------------
# Only used when an ingested PDF has no embedded text. Safe to leave blank.
GEMINI_API_KEY=
OCR_MODEL=gemini-3.1-flash-lite

# --- RAGAS judge (eval only — not needed to run the app) --------------------
# Default routes a Gemini judge through OpenRouter (reuses OPENROUTER_API_KEY).
JUDGE_PROVIDER=openrouter
OPENROUTER_JUDGE_MODEL=google/gemini-3.1-flash-lite
# Alternative judge providers (set JUDGE_PROVIDER to match):
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_JUDGE_MODEL=deepseek-v4-flash
# GEMINI_JUDGE_MODEL=gemini-2.5-flash      # JUDGE_PROVIDER=gemini (needs GEMINI_API_KEY w/ paid quota)

# --- Infra ------------------------------------------------------------------
# Redis caches embeddings (optional; app runs without it). Use a local Redis or
# a hosted (Upstash) rediss:// URL.
REDIS_URL=redis://localhost:6379
CHROMA_PERSIST_DIR=./chroma_store
SENTRY_DSN=

# CORS for the Angular SPA. "*" allows any origin; restrict in production.
CORS_ORIGINS=*

# --- Retrieval / chunking knobs ---------------------------------------------
CHUNK_SIZE=1024
CHUNK_OVERLAP=50
TOP_K=8
CACHE_TTL=86400
LOG_LEVEL=INFO
