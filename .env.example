GEMINI_API_KEY=your_gemini_api_key_here

# Answer-generation model (Gemini API, free-tier Gemma).
GEMMA_MODEL=gemma-4-31b-it

# --- RAGAS judge ------------------------------------------------------------
# JUDGE_PROVIDER selects which provider's credentials are used for the RAGAS
# judge. Valid values: "deepseek" | "openrouter" | "gemini". Default is
# DeepSeek (separate provider + model family from the Gemma generator).
JUDGE_PROVIDER=deepseek

# DeepSeek platform — fill this in for JUDGE_PROVIDER=deepseek.
# Available models: deepseek-v4-flash (default), deepseek-v4-pro,
# or legacy deepseek-chat / deepseek-reasoner (deprecated 2026-07-24).
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_JUDGE_MODEL=deepseek-v4-flash

# OpenRouter — fill OPENROUTER_API_KEY to enable JUDGE_PROVIDER=openrouter.
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_JUDGE_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free

# Gemini-as-judge — same family as the generator, reintroduces self-bias.
# Uses GEMINI_API_KEY above. Only override these to point at a different
# Gemini model.
# GEMINI_JUDGE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# GEMINI_JUDGE_MODEL=gemma-4-31b-it

# OCR model (scanned-page text extraction) and the text-embedding model.
OCR_MODEL=gemini-3.1-flash-lite
EMBEDDING_MODEL=models/gemini-embedding-001

GITHUB_TOKEN=your_github_token_here
GITHUB_MODEL=gpt-4o
GITHUB_API_BASE=https://models.inference.ai.azure.com

REDIS_URL=redis://localhost:6379
CHROMA_PERSIST_DIR=./chroma_store

SENTRY_DSN=

CHUNK_SIZE=1024
CHUNK_OVERLAP=50
TOP_K=8
CACHE_TTL=86400
LOG_LEVEL=INFO
